# Superuser/migration connection — used by Prisma Migrate and prisma/seed.ts only.
DATABASE_URL="postgresql://postgres:<password>@localhost:5432/tenderista?schema=public"

# Least-privilege runtime connection — used by the Next.js app for every request.
# The tenderista_app role is created by the initial migration with no password;
# set one with `ALTER ROLE tenderista_app WITH PASSWORD '...';` and put it here.
# Row-Level Security only takes effect for this role, not the superuser above.
APP_DATABASE_URL="postgresql://tenderista_app:<password>@localhost:5432/tenderista?schema=public"

# iron-session cookie encryption key — must be at least 32 characters.
SESSION_SECRET="<random 32+ character string>"
